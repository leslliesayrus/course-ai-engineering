# Copie para backend/.env (mesmo padrao do 01-simple-react-agent: o agent so carrega este arquivo).

# Obrigatorio: mesma chave para Gemini (chat) e embeddings nas tools
GOOGLE_API_KEY=

# Alternativa aceita pelo agent.py se GOOGLE_API_KEY estiver vazio
# GEMINI_API_KEY=

PINECONE_API_KEY=

# Chat (Gemini) — veja modelos em https://ai.google.dev/gemini-api/docs/models
GOOGLE_GENAI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_TEMPERATURE=0.2

# Embeddings nas tools (Pinecone) — igual ao test.py / ingest
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004
