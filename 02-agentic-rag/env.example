# Copie para .env e preencha. Pode ficar em 02-agentic-rag/.env ou em data-engineering/.env
# (se existirem os dois, o de data-engineering tem prioridade).

GROQ_API_KEY=
GOOGLE_API_KEY=

PINECONE_API_KEY=

# Opcional: modelo de embeddings (deve bater com a dimensão dos índices no Pinecone)
# Ex.: models/text-embedding-004 (768 dim)
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# Opcional: modelo Groq para resumos
GROQ_MODEL=llama-3.3-70b-versatile
